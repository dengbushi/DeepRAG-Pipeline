{
  "llm": {
    "provider": "deepseek",
    "api_key": "YOUR_DEEPSEEK_API_KEY_HERE",
    "base_url": "https://api.deepseek.com/v1",
    "model_name": "deepseek-v4-pro",
    "max_tokens": 393216,
    "temperature": 0.2,
    "timeout": 120
  },
  "search": {
    "engine": "deep_search",
    "serper_api_key": "YOUR_SERPER_API_KEY_HERE",
    "max_results": 10,
    "max_rounds": 8,
    "max_urls_per_step": 10,
    "token_budget": 600000,
    "allow_early_termination": true,
    "context_top_k": 40,
    "context_max_chars": 250000,
    "report_context_max_chars": 400000
  },
  "cache": {
    "enabled": true,
    "ttl": 3600,
    "max_size": 1000
  },
  "log": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file": "logs/rag_system.log"
  },
  "debug": false
}
